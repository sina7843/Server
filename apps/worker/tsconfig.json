{
  "extends": "../../packages/config/tsconfig/node.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": false,
    "types": ["node", "jest"],
    "esModuleInterop": true,
    "isolatedModules": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
