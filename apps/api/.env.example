NODE_ENV=development
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=3000

MONGODB_URI=mongodb://dragon_local:dragon_local_password@localhost:27017/dragon_local?authSource=admin
REDIS_URL=redis://localhost:6379

# ─── Redis / BullMQ (Task 0.8.3) ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

BULLMQ_DEFAULT_ATTEMPTS=3
BULLMQ_DEFAULT_BACKOFF_MS=2000
BULLMQ_PREFIX=dragon

# ─── Storage (Task 0.7.1) ────────────────────────────────────────────────────
# STORAGE_PROVIDER: local | minio | arvan
STORAGE_PROVIDER=local
STORAGE_BUCKET=dragon-local
STORAGE_PUBLIC_BASE_URL=http://localhost:3000/storage
STORAGE_SIGNED_URL_TTL_SECONDS=3600

# Local adapter (dev/fallback only — not production)
STORAGE_LOCAL_ROOT=/tmp/dragon-storage
STORAGE_LOCAL_PUBLIC_BASE_URL=http://localhost:3000/storage

# S3-compatible adapter (minio for local dev, arvan for production)
# Set STORAGE_PROVIDER=minio or STORAGE_PROVIDER=arvan and fill these in.
# Never commit real credentials.
STORAGE_S3_ENDPOINT=
STORAGE_S3_REGION=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_FORCE_PATH_STYLE=false

# ─── Media (Task 0.7.2) ──────────────────────────────────────────────────────
# Maximum upload size in bytes. Defaults to 10485760 (10 MB) if unset.
MEDIA_MAX_FILE_SIZE_BYTES=10485760

AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_PASSWORD_MIN_LENGTH=8
AUTH_OTP_TTL_SECONDS=300
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_OTP_RESEND_COOLDOWN_SECONDS=90
AUTH_OTP_DAILY_PHONE_LIMIT=10
AUTH_OTP_IP_LIMIT=30
AUTH_JWT_SECRET=local_dev_change_me_min_32_chars
AUTH_PASSWORD_RESET_TOKEN_TTL_SECONDS=600
SMS_PROVIDER=mock

# Optional seed-time assignment only. Must match an existing active user.
RBAC_BOOTSTRAP_SUPER_ADMIN_PHONE=

# ─── Backup (Task 0.10.4) ────────────────────────────────────────────────────
# Temporary directory for backup artifacts before upload. Never in repo source.
BACKUP_TEMP_DIR=/tmp/dragon-backups
# Optional: separate MongoDB URI for backup reads (defaults to MONGODB_URI if not set).
# BACKUP_MONGODB_URI=
# Object Storage prefix for backup artifacts (uses STORAGE_* config for credentials).
BACKUP_STORAGE_BUCKET_PREFIX=backups/mongodb
