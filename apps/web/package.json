{
  "name": "@dragon/web",
  "version": "0.0.0",
  "private": true,
  "description": "Minimal Dragon public web app shell.",
  "scripts": {
    "lint": "eslint \"nuxt.config.ts\" \"eslint.config.js\" \"composables/**/*.ts\" \"features/**/*.ts\" \"middleware/**/*.ts\" --no-error-on-unmatched-pattern",
    "typecheck": "nuxt typecheck",
    "test": "jest --runInBand features",
    "build": "nuxt build",
    "dev": "nuxt dev --host 0.0.0.0 --port 3000",
    "start": "node .output/server/index.mjs"
  },
  "dependencies": {
    "@dragon/sdk": "workspace:*",
    "@dragon/types": "workspace:*",
    "nuxt": "3.17.5",
    "vue": "3.5.16",
    "vue-router": "4.5.1"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "jest": "29.7.0",
    "ts-jest": "29.2.6",
    "vue-tsc": "2.2.10"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": "features/[^/]+/.*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "CommonJS",
            "moduleResolution": "Node"
          }
        }
      ]
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@dragon/sdk$": "<rootDir>/../../packages/sdk/src/index.ts",
      "^@dragon/types$": "<rootDir>/../../packages/types/src/index.ts"
    }
  }
}
