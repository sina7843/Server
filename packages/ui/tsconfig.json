{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../config/tsconfig/vue.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "dist",
    "types": ["vite/client"]
  },
  "include": ["env.d.ts", "src/**/*.ts", "src/**/*.vue", "vite.config.ts"],
  "exclude": ["dist", "node_modules"]
}
