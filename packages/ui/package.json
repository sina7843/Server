{
  "name": "@dragon/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Vue UI component package skeleton for Dragon Ecosystem.",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "lint": "eslint \"src/**/*.ts\" \"vite.config.ts\" \"env.d.ts\" --no-error-on-unmatched-pattern",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "node -e \"console.log('No runtime tests configured for @dragon/ui skeleton yet.')\"",
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly -p tsconfig.json --outDir dist"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "5.2.4",
    "vite": "6.4.2",
    "vue": "3.5.16",
    "vue-tsc": "2.2.10"
  }
}
