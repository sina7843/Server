# Dragon Ecosystem — Production Environment Example
#
# Copy this file to .env.production and fill in all CHANGE_ME values.
# Never commit .env.production to the repository.
# All values here are placeholders only. No real credentials are present.
#
# Used by: infra/docker/docker-compose.prod.yml
#   docker compose -f infra/docker/docker-compose.prod.yml --env-file infra/docker/.env.production.example config

# ─── App Environment ──────────────────────────────────────────────────────────
NODE_ENV=production
APP_ENV=production

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Credentials used by the mongodb service to create the initial database user.
# MONGODB_URI must use the same username/password.
MONGO_INITDB_ROOT_USERNAME=dragon_prod
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD
MONGO_INITDB_DATABASE=dragon_prod

# Connection string used by the api and worker containers.
# Host must be the compose service name: mongodb
MONGODB_URI=mongodb://dragon_prod:CHANGE_ME_STRONG_RANDOM_PASSWORD@mongodb:27017/dragon_prod?authSource=admin

# ─── Redis / BullMQ ──────────────────────────────────────────────────────────
# Host must be the compose service name: redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

BULLMQ_PREFIX=dragon
BULLMQ_DEFAULT_ATTEMPTS=3
BULLMQ_DEFAULT_BACKOFF_MS=2000

# ─── JWT / Auth ───────────────────────────────────────────────────────────────
# Use a cryptographically random string of at least 64 characters.
# Generate: openssl rand -hex 64
AUTH_JWT_SECRET=CHANGE_ME_MIN_64_RANDOM_CHARACTERS
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_PASSWORD_MIN_LENGTH=8

# ─── OTP ─────────────────────────────────────────────────────────────────────
AUTH_OTP_TTL_SECONDS=300
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_OTP_RESEND_COOLDOWN_SECONDS=90
AUTH_OTP_DAILY_PHONE_LIMIT=10
AUTH_OTP_IP_LIMIT=30
AUTH_PASSWORD_RESET_TOKEN_TTL_SECONDS=600

# ─── SMS Provider ─────────────────────────────────────────────────────────────
# Set to kavenegar (or another provider) and supply the API key for production.
# SMS_PROVIDER=mock has no real delivery — use only for staging.
SMS_PROVIDER=mock
# SMS_PROVIDER=kavenegar
# SMS_API_KEY=CHANGE_ME

# ─── Arvan Object Storage (S3-compatible) ────────────────────────────────────
# Object Storage is external — not a compose service.
# Obtain credentials from the Arvan Cloud console.
# Never commit the real ACCESS_KEY_ID or SECRET_ACCESS_KEY.
STORAGE_PROVIDER=arvan
STORAGE_BUCKET=CHANGE_ME_BUCKET_NAME
STORAGE_PUBLIC_BASE_URL=https://CHANGE_ME_BUCKET_NAME.storage.c2.arvanstorage.ir
STORAGE_SIGNED_URL_TTL_SECONDS=3600

STORAGE_S3_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
STORAGE_S3_REGION=ir-thr-at1
STORAGE_S3_ACCESS_KEY_ID=CHANGE_ME_ARVAN_ACCESS_KEY
STORAGE_S3_SECRET_ACCESS_KEY=CHANGE_ME_ARVAN_SECRET_KEY
STORAGE_S3_FORCE_PATH_STYLE=false

# ─── Media ───────────────────────────────────────────────────────────────────
# Maximum upload size in bytes. Must align with nginx client_max_body_size (50m).
MEDIA_MAX_FILE_SIZE_BYTES=52428800

# ─── Public Web URLs (Nuxt web container) ────────────────────────────────────
# NUXT_API_INTERNAL_BASE_URL: server-side SSR requests use the internal service name.
# NUXT_PUBLIC_API_BASE_URL:   browser requests use the public domain.
NUXT_API_INTERNAL_BASE_URL=http://api:3000
NUXT_PUBLIC_API_BASE_URL=https://api.YOUR_DOMAIN
NUXT_PUBLIC_SITE_URL=https://YOUR_DOMAIN
NUXT_PUBLIC_APP_ENV=production
NUXT_PUBLIC_APP_NAME=Dragon Web

# ─── Admin URLs (Nuxt admin container) ───────────────────────────────────────
NUXT_PUBLIC_ADMIN_URL=https://admin.YOUR_DOMAIN
# NUXT_PUBLIC_API_BASE_URL is shared with the web section above.

# ─── RBAC Bootstrap (seed-time only, not used at request time) ───────────────
# Set once to assign super_admin to an existing active user. Leave empty otherwise.
RBAC_BOOTSTRAP_SUPER_ADMIN_PHONE=

# ─── Backup (Task 0.10.4) ────────────────────────────────────────────────────
# Local temp dir on the VPS for staging backup archives before upload.
# Must be writable and on a volume with enough space.
BACKUP_TEMP_DIR=/tmp/dragon-backups
# Prefix within the Object Storage bucket used for backup archives.
# Must NOT overlap with the media prefix.
BACKUP_STORAGE_BUCKET_PREFIX=backups/mongodb
# Encryption is NOT implemented in Phase 0 — required before production.
# See docs/security/backup-security-checklist.md.

# ─── Logging ──────────────────────────────────────────────────────────────────
# Structured logging levels: error | warn | log | debug | verbose
LOG_LEVEL=warn

# ─── Worker ──────────────────────────────────────────────────────────────────
WORKER_NAME=dragon-worker
