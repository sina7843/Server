{
  "name": "@dragon/api",
  "version": "0.0.0",
  "private": true,
  "description": "Minimal Dragon API app shell.",
  "scripts": {
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest",
    "build": "tsc -p tsconfig.build.json",
    "seed:rbac": "node dist/rbac/seeds/run-rbac-seed.js",
    "start": "node dist/main.js",
    "dev": "tsc --watch -p tsconfig.build.json"
  },
  "dependencies": {
    "@dragon/utils": "workspace:*",
    "@nestjs/common": "10.4.20",
    "@nestjs/core": "10.4.20",
    "@nestjs/mongoose": "10.1.0",
    "@nestjs/platform-express": "10.4.20",
    "argon2": "0.41.1",
    "mongoose": "8.16.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "@dragon/types": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "20.14.10",
    "jest": "29.7.0",
    "ts-jest": "29.2.6",
    "@nestjs/testing": "10.4.20"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "CommonJS",
            "moduleResolution": "Node"
          }
        }
      ]
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@dragon/utils$": "<rootDir>/../../packages/utils/src/index.ts",
      "^@dragon/types$": "<rootDir>/../../packages/types/src/index.ts"
    }
  }
}
