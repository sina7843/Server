{
  "name": "@dragon/worker",
  "version": "0.0.0",
  "private": true,
  "description": "Minimal Dragon worker runtime shell.",
  "main": "dist/main.js",
  "scripts": {
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "tsc --watch -p tsconfig.json"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "20.14.10",
    "jest": "29.7.0",
    "ts-jest": "29.2.6"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node"
  },
  "dependencies": {
    "bullmq": "5.77.2",
    "mongoose": "8.16.0"
  }
}
