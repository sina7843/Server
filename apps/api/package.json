{
  "name": "@dragon/api",
  "version": "0.0.0",
  "private": true,
  "description": "Minimal Dragon API app shell.",
  "scripts": {
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest",
    "smoke": "jest --testRegex=\".*\\.e2e-spec\\.ts$\" --testPathPattern=\"smoke\" --runInBand",
    "smoke:phase0": "jest --testRegex=\".*\\.e2e-spec\\.ts$\" --testPathPattern=\"auth-login|auth-refresh|auth-register|auth-full-flow|auth-security|rbac-admin|rbac-authorization|profile-account|profile-public|content-admin|content-public\" --runInBand",
    "build": "tsc -p tsconfig.build.json",
    "seed:rbac": "node dist/rbac/seeds/run-rbac-seed.js",
    "start": "node dist/main.js",
    "dev": "concurrently -k -n api:build,api:serve -c blue,cyan \"tsc --watch -p tsconfig.build.json\" \"wait-on dist/main.js && node --env-file=.env.example --watch dist/main.js\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.799.0",
    "@aws-sdk/s3-request-presigner": "3.799.0",
    "@dragon/types": "workspace:*",
    "@dragon/utils": "workspace:*",
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "10.4.20",
    "@nestjs/core": "10.4.20",
    "@nestjs/event-emitter": "3.1.0",
    "@nestjs/mongoose": "10.1.0",
    "@nestjs/platform-express": "10.4.20",
    "argon2": "0.41.1",
    "bullmq": "5.77.2",
    "mongoose": "8.16.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "sanitize-html": "^2.13.0",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@nestjs/testing": "10.4.20",
    "@types/jest": "29.5.14",
    "@types/multer": "1.4.12",
    "@types/node": "20.14.10",
    "@types/sanitize-html": "^2.13.0",
    "@types/sharp": "0.32.0",
    "jest": "29.7.0",
    "ts-jest": "29.2.6"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "CommonJS",
            "moduleResolution": "Node",
            "esModuleInterop": true
          }
        }
      ]
    },
    "testEnvironment": "node",
    "maxWorkers": 2,
    "moduleNameMapper": {
      "^@dragon/utils$": "<rootDir>/../../packages/utils/src/index.ts",
      "^@dragon/types$": "<rootDir>/../../packages/types/src/index.ts"
    }
  }
}
