# Local-only development values. Do not use for production.
MONGO_INITDB_ROOT_USERNAME=dragon_local
MONGO_INITDB_ROOT_PASSWORD=dragon_local_password
MONGO_INITDB_DATABASE=dragon_local

MINIO_ROOT_USER=dragon_local
MINIO_ROOT_PASSWORD=dragon_local_password
# Bucket to create on MinIO startup (align with STORAGE_BUCKET in apps/api/.env)
MINIO_DEFAULT_BUCKETS=dragon-local
